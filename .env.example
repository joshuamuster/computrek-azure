# ══════════════════════════════════════════════════════════════════════════════
# CompuTrek Azure — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env.
# ══════════════════════════════════════════════════════════════════════════════

# ── Phase 1: Microsoft / Azure AD Auth ────────────────────────────────────────
# Provided by district IT when they register the app in Azure AD.
# Leave blank during dev to allow any Microsoft account (tenant = 'common').
VITE_AZURE_TENANT_ID=your_district_tenant_guid_here
VITE_AZURE_CLIENT_ID=your_app_registration_client_id_here

# ── Firebase (kept through Phase 5 — Firestore is still the database) ─────────
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here
VITE_FIREBASE_DATABASE_URL=https://your_project-default-rtdb.firebaseio.com

# ── Phase 2: Azure Cosmos DB (uncomment when Phase 2 begins) ──────────────────
# VITE_COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/
# VITE_COSMOS_KEY=your_cosmos_primary_key_here

# ── Phase 3: Azure SignalR (uncomment when Phase 3 begins) ────────────────────
# VITE_SIGNALR_HUB_URL=/api/hub
# (actual SignalR connection string stays server-side in Azure Functions config)

# ── Phase 5: Azure Blob Storage (uncomment when Phase 5 begins) ───────────────
# VITE_AZURE_STORAGE_URL=https://your_account.blob.core.windows.net
# (connection string stays server-side in Azure Functions config)

# ── Jeopardy / Sheets (optional — keep if still in use) ───────────────────────
VITE_GOOGLE_SHEETS_API_KEY=your_api_key_here
VITE_JEOPARDY_SPREADSHEET_ID=your_spreadsheet_id_here

# ── Google Drive course materials (optional) ──────────────────────────────────
VITE_DRIVE_SCRIPT_URL=your_apps_script_url_here
VITE_DRIVE_UNIT00_FOLDER_ID=your_unit00_folder_id_here
VITE_DRIVE_UNIT01_FOLDER_ID=your_unit01_folder_id_here
VITE_DRIVE_UNIT02_FOLDER_ID=your_unit02_folder_id_here
VITE_DRIVE_UNIT03B_FOLDER_ID=your_unit03b_folder_id_here
VITE_DRIVE_UNIT05_FOLDER_ID=your_unit05_folder_id_here
