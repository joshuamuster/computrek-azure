VITE_GOOGLE_SHEETS_API_KEY=your_api_key_here
VITE_JEOPARDY_SPREADSHEET_ID=your_spreadsheet_id_here

# Google Drive folder IDs for course materials (PDFs, PPTx).
# Each value is the ID from the folder's URL:
#   https://drive.google.com/drive/folders/<FOLDER_ID>
# Leave blank to skip that unit (it will fall back to locally bundled files).
# The same API key above is reused — make sure the Drive API is enabled
# on your Google Cloud project.
# Google Apps Script web app URL (used to list Drive folder contents).
# See: https://script.google.com → Deploy → New deployment → Web app
VITE_DRIVE_SCRIPT_URL=your_apps_script_url_here

VITE_DRIVE_UNIT00_FOLDER_ID=your_unit00_folder_id_here
VITE_DRIVE_UNIT01_FOLDER_ID=your_unit01_folder_id_here
VITE_DRIVE_UNIT02_FOLDER_ID=your_unit02_folder_id_here
VITE_DRIVE_UNIT03B_FOLDER_ID=your_unit03b_folder_id_here
VITE_DRIVE_UNIT05_FOLDER_ID=your_unit05_folder_id_here
